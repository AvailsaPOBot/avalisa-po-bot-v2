{
  "manifest_version": 3,
  "name": "Avalisa Trading Strategy Tool",
  "version": "2.3.14",
  "description": "Advanced trading strategy assistant for Pocket Option. Automate your strategies with precision and full control.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://pocketoption.com/*",
    "https://po.cash/*",
    "https://po.trade/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://pocketoption.com/*", "https://po.cash/*", "https://po.trade/*"],
      "js": ["injected.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://pocketoption.com/*", "https://po.cash/*", "https://po.trade/*"],
      "js": ["signalEngine.js", "config.js", "state.js", "apiClient.js", "storage.js", "indicators.js", "overlayView.js", "claimFlow.js", "content.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["injected.js", "icons/AvalisaBot_Logo.png"],
      "matches": ["https://pocketoption.com/*", "https://po.cash/*", "https://po.trade/*"]
    }
  ]
}
