# ── Required ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:6543/postgres?pgbouncer=true&connection_limit=1
DIRECT_URL=postgresql://user:password@host:5432/postgres
JWT_SECRET=change_this_to_a_random_64_char_string

# Google Gemini — FREE, get at https://aistudio.google.com
GOOGLE_AI_API_KEY=your_gemini_api_key_here

# ── Whop (payments) ──────────────────────────────────────────────────────────
WHOP_WEBHOOK_SECRET=your_whop_webhook_signing_secret
WHOP_PLAN_ID_BASIC=plan_xxxxxxxxxxxxxx
WHOP_PLAN_ID_LIFETIME=plan_xxxxxxxxxxxxxx

# ── Optional: Claude AI (upgrades support chat quality) ──────────────────────
# ANTHROPIC_API_KEY=your_anthropic_key_here

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
FRONTEND_URL=https://avalisabot.vercel.app
