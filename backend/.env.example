# ── Required ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname
JWT_SECRET=change_this_to_a_random_64_char_string

# Google Gemini — FREE, get at https://aistudio.google.com
GOOGLE_AI_API_KEY=your_gemini_api_key_here

# ── Lemon Squeezy (payments) ─────────────────────────────────────────────────
LEMONSQUEEZY_API_KEY=your_ls_api_key
LEMONSQUEEZY_WEBHOOK_SECRET=your_ls_webhook_secret
LEMONSQUEEZY_STORE_ID=your_store_id
LEMONSQUEEZY_VARIANT_ID_BASIC=variant_id_for_50_plan
LEMONSQUEEZY_VARIANT_ID_LIFETIME=variant_id_for_100_plan

# ── Optional: Claude AI (upgrades support chat quality) ──────────────────────
# ANTHROPIC_API_KEY=your_anthropic_key_here

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
FRONTEND_URL=https://your-dashboard-domain.com
