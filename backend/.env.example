# ── Required ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:6543/postgres?pgbouncer=true&connection_limit=1
DIRECT_URL=postgresql://user:password@host:5432/postgres
JWT_SECRET=change_this_to_a_random_64_char_string

# Google Gemini — FREE, get at https://aistudio.google.com
GOOGLE_AI_API_KEY=your_gemini_api_key_here

# ── Whop (payments) ──────────────────────────────────────────────────────────
WHOP_WEBHOOK_SECRET=your_whop_webhook_signing_secret
WHOP_PLAN_ID_BASIC=plan_xxxxxxxxxxxxxx
WHOP_PLAN_ID_PRO=plan_xxxxxxxxxxxxxx

# ── Optional: Claude AI (upgrades support chat quality) ──────────────────────
# ANTHROPIC_API_KEY=your_anthropic_key_here

# ── Email (Gmail SMTP) — powers password reset ──────────────────────────────
# GMAIL_APP_PASSWORD is a Google "App Password" (16 chars). Requires 2-Step
# Verification enabled on the account, then create one at
# https://myaccount.google.com/apppasswords
GMAIL_USER=avalisapobot@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password
EMAIL_FROM=Avalisa PO Bot <avalisapobot@gmail.com>

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
FRONTEND_URL=https://avalisabot.vercel.app
PUBLIC_BACKEND_URL=https://avalisa-backend.onrender.com

# ── Social sign in / sign up ────────────────────────────────────────────────
# Google redirect URI: https://avalisa-backend.onrender.com/api/auth/oauth/google/callback
GOOGLE_OAUTH_CLIENT_ID=your_google_oauth_client_id
GOOGLE_OAUTH_CLIENT_SECRET=your_google_oauth_client_secret

# Facebook redirect URI: https://avalisa-backend.onrender.com/api/auth/oauth/facebook/callback
FACEBOOK_OAUTH_CLIENT_ID=your_facebook_oauth_app_id
FACEBOOK_OAUTH_CLIENT_SECRET=your_facebook_oauth_app_secret
