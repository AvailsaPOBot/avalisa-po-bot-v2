generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  poUserId     String?   @unique
  isAdmin      Boolean   @default(false)
  createdAt    DateTime  @default(now())

  license      License?
  trades       Trade[]
  settings     Settings?
  fingerprints DeviceFingerprint[]
  aiSlot       AiSlot?
  tokenUsage   UserTokenUsage[]
}

model License {
  id                    String    @id @default(cuid())
  userId                String    @unique
  plan                  String    @default("free") // free | basic | lifetime
  tradesUsed            Int       @default(0)
  tradesLimit           Int?      // null = unlimited
  expiresAt             DateTime?
  lemonsqueezyOrderId   String?
  claimStatus           String    @default("none") // none | pending | approved | rejected
  claimNote             String?
  claimedPoUid          String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Trade {
  id            String   @id @default(cuid())
  userId        String
  pair          String
  direction     String   // call | put
  amount        Float
  result        String   // win | loss | pending
  balanceBefore Float?
  balanceAfter  Float?
  isDemo        Boolean  @default(false)
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Settings {
  id                   String   @id @default(cuid())
  userId               String   @unique
  strategy             String   @default("martingale") // martingale | anti-martingale | fixed | ai-signal
  timeframe            String   @default("M1") // M1 | M3 | M5 | M30 | H1 | H4
  direction            String   @default("alternating") // alternating | call | put
  martingaleMultiplier Float    @default(2.0)
  martingaleSteps      String   @default("infinite") // number or "infinite"
  delaySeconds         Int      @default(6)
  startAmount          Float    @default(1.0)
  updatedAt            DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DeviceFingerprint {
  id             String   @id @default(cuid())
  fingerprint    String   @unique
  userId         String?
  freeTradesUsed Int      @default(0)
  createdAt      DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model AffiliateReferral {
  id        String   @id @default(cuid())
  poUid     String   @unique
  event     String
  createdAt DateTime @default(now())
}

model AppConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model AiSlot {
  id        String   @id @default(cuid())
  userId    String   @unique
  name      String   @default("My AI Bot")
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserTokenUsage {
  id         String @id @default(cuid())
  userId     String
  tokensUsed Int    @default(0)
  month      String
  user       User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([userId, month])
}
